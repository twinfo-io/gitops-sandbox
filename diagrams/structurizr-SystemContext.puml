@startuml
title <size:24>System Context View: gitops-sandbox</size>\n<size:24>Nivel 1 — quem usa o sistema e com quais sistemas externos ele conversa.</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>

Person(PMDev, "PM / Dev", $descr="Escreve specs, adiciona labels de agent na issue, revisa e aprova PRs. Nunca faz merge automatico.", $tags="", $link="")
System(gitopssandbox, "gitops-sandbox", $descr="Orquestra a execucao de agentes Claude a partir de labels do Linear, com gates de seguranca e verificacao real de resultado.", $tags="", $link="")
System(Linear, "Linear", $descr="Fonte da verdade de tarefas. Emite webhooks, recebe comentarios, documentos e mudancas de estado via GraphQL.", $tags="", $link="")
System(GitHub, "GitHub", $descr="Hospeda o codigo, roda o GitHub Actions e expõe a REST API de PRs/branches/workflow_dispatch.", $tags="", $link="")
System(AnthropicAPI, "Anthropic API", $descr="Modelos Claude (Haiku 4.5 / Sonnet 5) que executam o raciocinio e as acoes do agente.", $tags="", $link="")

Rel(PMDev, gitopssandbox, "Adiciona labels de agent, escreve specs, revisa e aprova PRs", $techn="", $tags="", $link="")
Rel(PMDev, Linear, "Escreve specs, adiciona labels de agent na issue", $techn="", $tags="", $link="")
Rel(PMDev, GitHub, "Revisa e aprova PRs gerados pelo agente", $techn="", $tags="", $link="")
Rel(gitopssandbox, Linear, "Le/escreve issues, comentarios e documentos", $techn="GraphQL API", $tags="", $link="")
Rel(gitopssandbox, GitHub, "Dispara workflows, abre PRs e branches", $techn="REST API", $tags="", $link="")
Rel(gitopssandbox, AnthropicAPI, "Executa o raciocinio do agente", $techn="HTTPS API", $tags="", $link="")
Rel(Linear, gitopssandbox, "Emite evento de issue", $techn="Webhook HTTPS + HMAC-SHA256", $tags="", $link="")
Rel(GitHub, gitopssandbox, "Inicia a execucao do job no runner", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml