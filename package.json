{
  "name": "gitops-sandbox",
  "version": "1.0.0",
  "private": true,
  "description": "GitOps × Claude Agents — Sandbox Twinfo",
  "scripts": {
    "dev": "vercel dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "sync": "tsx src/scripts/sync-project.ts",
    "sync:pull": "tsx src/scripts/sync-project.ts --pull",
    "sync:push": "tsx src/scripts/sync-project.ts --push",
    "sync:both": "tsx src/scripts/sync-project.ts --both",
    "parse-pr": "tsx src/scripts/parse-pr.ts",
    "create-demand": "tsx src/scripts/create-demand.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
